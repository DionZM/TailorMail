<Page x:Class="TailorMail.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="设置">
    <ScrollViewer Margin="24,16,24,8" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="设置" Style="{StaticResource PageTitleStyle}" Margin="0,0,0,8"/>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,6" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="发送方式" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8"/>
                    <RadioButton Content="通过 Outlook 发送" Margin="0,0,0,6"
                                 IsChecked="{Binding SendMethod, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Outlook}"/>
                    <StackPanel Margin="20,0,0,6">
                        <ui:InfoBar Title="Outlook 发送"
                                    Message="需要本机已安装并配置 Microsoft Outlook。"
                                    IsOpen="{Binding IsOutlookAvailable}" IsClosable="False" Severity="Success"/>
                        <ui:InfoBar Title="Outlook 不可用"
                                    Message="未检测到 Outlook，请使用 SMTP 方式发送。"
                                    IsOpen="{Binding IsOutlookAvailable, Converter={StaticResource InverseBoolConverter}}"
                                    IsClosable="False" Severity="Warning"/>
                    </StackPanel>
                    <RadioButton Content="通过 SMTP 发送"
                                 IsChecked="{Binding SendMethod, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Smtp}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,6" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="SMTP 配置" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8"/>
                    <ui:InfoBar Title="安全提示" Message="密码仅在发送时输入，不会保存到配置文件中。"
                                IsOpen="True" IsClosable="False" Severity="Informational" Margin="0,0,0,8"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Text="服务器" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <ui:TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SmtpHost, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="如：smtp.example.com" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1" Text="端口" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <ui:NumberBox Grid.Row="1" Grid.Column="1" Value="{Binding SmtpPort}" Minimum="1" Maximum="65535"
                                      Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="2" Text="SSL" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <ui:ToggleSwitch Grid.Row="2" Grid.Column="1" IsChecked="{Binding SmtpUseSsl}" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="3" Text="用户名" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <ui:TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SmtpUserName, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="SMTP 登录用户名" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="4" Text="发件人" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <ui:TextBox Grid.Row="4" Grid.Column="1" Text="{Binding SmtpDisplayName, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="收件人看到的发件人名称" Margin="0,0,0,6"/>
                    </Grid>
                </StackPanel>
            </Border>

            <ui:Button Content="保存设置" Icon="{ui:SymbolIcon Save24}" Appearance="Primary"
                       Command="{Binding SaveCommand}" HorizontalAlignment="Right" Padding="16,4"/>
        </StackPanel>
    </ScrollViewer>
</Page>
