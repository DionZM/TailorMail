<ui:FluentWindow x:Class="TailorMail.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="发送配置" Height="580" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="{StaticResource UIFontFamily}"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="发送配置" FontSize="{StaticResource FontSizeXL}" FontWeight="Bold"
                       FontFamily="{StaticResource DisplayFontFamily}" Foreground="{StaticResource TextPrimaryBrush}"/>
            <Border Style="{StaticResource PageTitleAccentStyle}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Style="{StaticResource SectionTitleAccentStyle}"/>
                            <TextBlock Text="发送通道" Style="{StaticResource SectionTitleStyle}"/>
                        </StackPanel>
                        <ComboBox x:Name="CmbChannel" SelectedIndex="0" Padding="8,6" SelectionChanged="OnChannelChanged">
                            <ComboBoxItem Content="Outlook"/>
                            <ComboBoxItem Content="SMTP"/>
                        </ComboBox>
                        <StackPanel Margin="0,8,0,0">
                            <ui:InfoBar x:Name="OutlookAvailableBar"
                                        Title="Outlook 可用"
                                        Message="已检测到本机 Outlook，可直接使用。"
                                        IsOpen="True" IsClosable="False" Severity="Success"/>
                            <ui:InfoBar x:Name="OutlookUnavailableBar"
                                        Title="Outlook 不可用"
                                        Message="未检测到 Outlook，请使用 SMTP 方式发送。"
                                        IsOpen="False" IsClosable="False" Severity="Warning"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Style="{StaticResource SectionTitleAccentStyle}"/>
                            <TextBlock Text="SMTP 配置" Style="{StaticResource SectionTitleStyle}"/>
                        </StackPanel>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Text="SMTP服务器" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <ui:TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtServer" Margin="0,0,0,8"
                                        PlaceholderText="如：smtp.example.com"/>

                            <TextBlock Grid.Row="1" Text="端口" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <ui:NumberBox Grid.Row="1" Grid.Column="1" x:Name="TxtPort" Value="587" Minimum="1" Maximum="65535" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Text="启用SSL" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <ui:ToggleSwitch Grid.Row="2" Grid.Column="1" x:Name="ChkSsl" IsChecked="True" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="3" Text="用户名" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <ui:TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtUsername" Margin="0,0,0,8"
                                        PlaceholderText="SMTP登录用户名"/>

                            <TextBlock Grid.Row="4" Text="发件人名称" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <ui:TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtSenderName" Margin="0,0,0,8"
                                        PlaceholderText="收件人看到的发件人名称"/>

                            <TextBlock Grid.Row="5" Text="发件人邮箱" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <ui:TextBox Grid.Row="5" Grid.Column="1" x:Name="TxtSenderEmail" Margin="0,0,0,8"
                                        PlaceholderText="收件人看到的发件人地址"/>

                            <Border Grid.Row="6" Grid.ColumnSpan="2" Background="{StaticResource AccentLightBrush}"
                                    CornerRadius="{StaticResource CornerRadiusSM}" Padding="12,8" Margin="0,4,0,0">
                                <TextBlock Text="💡 发件人邮箱可与登录用户名不同，部分SMTP服务器要求两者一致"
                                           Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap"
                                           Foreground="{StaticResource AccentBrush}"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Click="BtnCancel_Click" Padding="20,8" Margin="0,0,8,0"/>
            <ui:Button Content="保存配置" Click="BtnSave_Click" Padding="20,8" Appearance="Primary"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
