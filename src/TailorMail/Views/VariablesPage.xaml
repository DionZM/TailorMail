<UserControl x:Class="TailorMail.Views.VariablesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,16" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <WrapPanel Grid.Column="0" Orientation="Horizontal">
                    <ui:TextBox x:Name="NewVarTextBox" Text="{Binding NewVariableName,UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="新变量名" Width="120" Margin="0,0,8,0" KeyDown="OnNewVarKeyDown"/>
                    <Button Content="添加变量" Click="OnAddVariableClick" Margin="0,0,4,0" Padding="12,6"/>
                    <Button Content="删除变量" Click="OnDeleteVariable" Margin="0,0,4,0" Padding="12,6"/>
                </WrapPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="导出" Command="{Binding ExportVariablesCommand}" Margin="0,0,4,0" Padding="12,6"/>
                    <Button Content="导入" Command="{Binding ImportVariablesCommand}" Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Border Style="{StaticResource CardStyle}" Margin="0">
                <DataGrid x:Name="VariablesGrid" AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal" AlternatingRowBackground="{StaticResource SurfaceBrush}"
                          FontSize="13" FontFamily="{StaticResource UIFontFamily}"
                          CellEditEnding="OnCellEditEnding"
                          PreviewKeyDown="OnGridPreviewKeyDown"
                          BorderThickness="0" Background="Transparent"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          RowStyle="{StaticResource HoverRowStyle}"/>
            </Border>
            <Border x:Name="VarEmptyState" Style="{StaticResource EmptyStateStyle}" Visibility="Collapsed">
                <StackPanel>
                    <ui:SymbolIcon Symbol="Tag24" Style="{StaticResource EmptyStateIconStyle}"/>
                    <TextBlock Text="暂无变量" Style="{StaticResource EmptyStateTextStyle}" Margin="0,0,0,4"/>
                    <TextBlock Text="请在上方输入变量名并点击添加" Style="{StaticResource CaptionTextStyle}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border x:Name="VarErrorState" Style="{StaticResource ErrorStateStyle}" Visibility="Collapsed">
                <StackPanel>
                    <ui:SymbolIcon Symbol="ErrorCircle24" Style="{StaticResource EmptyStateIconStyle}" Foreground="{StaticResource DangerBrush}"/>
                    <TextBlock Text="数据加载失败" Style="{StaticResource EmptyStateTextStyle}" Foreground="{StaticResource DangerBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="请检查数据库连接后重试" Style="{StaticResource CaptionTextStyle}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
