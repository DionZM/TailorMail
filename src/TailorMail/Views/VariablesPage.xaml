<UserControl x:Class="TailorMail.Views.VariablesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Border Style="{StaticResource CardStyle}" Margin="0" Padding="16,8">
                <WrapPanel Orientation="Horizontal">
                    <ui:TextBox x:Name="NewVarTextBox" Text="{Binding NewVariableName,UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="新变量名" Width="120" Margin="0,0,8,0" KeyDown="OnNewVarKeyDown"/>
                    <Button Content="添加变量" Click="OnAddVariableClick" Margin="0,0,4,0" Padding="12,6"/>
                    <Button Content="删除变量" Click="OnDeleteVariable" Margin="0,0,4,0" Padding="12,6"/>
                </WrapPanel>
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                <Button Content="导出" Command="{Binding ExportVariablesCommand}" Margin="0,0,4,0" Padding="12,6"/>
                <Button Content="导入" Command="{Binding ImportVariablesCommand}" Padding="12,6"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Border Style="{StaticResource CardStyle}" Margin="0">
                <DataGrid x:Name="VariablesGrid" AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal" AlternatingRowBackground="{StaticResource SurfaceBrush}"
                          FontSize="13" FontFamily="{StaticResource AppFontFamily}"
                          CellEditEnding="OnCellEditEnding"
                          PreviewKeyDown="OnGridPreviewKeyDown"
                          BorderThickness="0" Background="Transparent"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"/>
            </Border>
            <Border x:Name="VarEmptyState" Style="{StaticResource EmptyStateStyle}" Visibility="Collapsed">
                <StackPanel>
                    <ui:SymbolIcon Symbol="Tag24" Style="{StaticResource EmptyStateIconStyle}"/>
                    <TextBlock Text="暂无变量" Style="{StaticResource EmptyStateTextStyle}" Margin="0,0,0,4"/>
                    <TextBlock Text="请在上方输入变量名并点击添加" Style="{StaticResource CaptionTextStyle}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
