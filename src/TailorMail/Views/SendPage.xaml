<UserControl x:Class="TailorMail.Views.SendPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="批量发送" Style="{StaticResource PageTitleStyle}" Margin="0,0,0,4"/>
            <TextBlock x:Name="TxtChannelHint" Style="{StaticResource CaptionTextStyle}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="发送进度" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                <ProgressBar Grid.Column="1" x:Name="ProgressBar" Height="8" Maximum="100"
                             Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Grid.Column="2" x:Name="TxtProgress" Text="0/0" VerticalAlignment="Center"
                           FontWeight="SemiBold" Margin="12,0,0,0" Foreground="{StaticResource TextPrimaryBrush}"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="筛选：" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0" FontSize="13"/>
            <RadioButton x:Name="FilterAll" Content="全部" IsChecked="True" Click="OnFilterChanged" Margin="0,0,8,0"
                         FontSize="13" FontFamily="{StaticResource AppFontFamily}"/>
            <RadioButton x:Name="FilterSuccess" Content="成功" Click="OnFilterChanged" Margin="0,0,8,0"
                         Foreground="{StaticResource SuccessBrush}" FontSize="13" FontFamily="{StaticResource AppFontFamily}"/>
            <RadioButton x:Name="FilterFailed" Content="失败" Click="OnFilterChanged" Margin="0,0,8,0"
                         Foreground="{StaticResource DangerBrush}" FontSize="13" FontFamily="{StaticResource AppFontFamily}"/>
            <RadioButton x:Name="FilterPending" Content="等待" Click="OnFilterChanged"
                         Foreground="{StaticResource TextTertiaryBrush}" FontSize="13" FontFamily="{StaticResource AppFontFamily}"/>
        </StackPanel>

        <Grid Grid.Row="3">
            <Border Style="{StaticResource CardStyle}" Margin="0">
                <DataGrid x:Name="DataGridResults" AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal" AlternatingRowBackground="{StaticResource SurfaceBrush}"
                          FontSize="13" FontFamily="{StaticResource AppFontFamily}"
                          BorderThickness="0" Background="Transparent">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="发送对象" Binding="{Binding RecipientName}" Width="200">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Medium"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="状态" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontSize="14" Margin="0,0,4,0" VerticalAlignment="Center" FontFamily="Segoe UI Emoji">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="⏳"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Success">
                                                            <Setter Property="Text" Value="✅"/>
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Text" Value="❌"/>
                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Sending">
                                                            <Setter Property="Text" Value="📤"/>
                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Success">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Sending">
                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="发送时间" Binding="{Binding SendTime,StringFormat='{}{0:HH:mm:ss}'}" Width="80"/>
                        <DataGridTextColumn Header="错误信息" Binding="{Binding ErrorMessage}" Width="*"/>
                        <DataGridTemplateColumn Header="操作" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="重试" Click="OnRetry" Tag="{Binding RecipientId}" Padding="8,3" FontSize="12"
                                            Visibility="{Binding Status,Converter={StaticResource FailedToVisibilityConverter}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
            <Border x:Name="LoadingOverlay" Background="#80FFFFFF" CornerRadius="8" Visibility="Collapsed"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ui:ProgressRing IsIndeterminate="True" Width="32" Height="32" Margin="0,0,0,8"/>
                    <TextBlock x:Name="LoadingText" Text="正在发送邮件..." Style="{StaticResource CaptionTextStyle}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
