<UserControl x:Class="TailorMail.Views.RecipientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="对象选择" Style="{StaticResource PageTitleStyle}" Margin="0,0,0,4"/>
            <TextBlock Style="{StaticResource CaptionTextStyle}">
                <Run Text="已选 "/><Run Text="{Binding SelectedCount,Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                <Run Text=" / 共 "/><Run Text="{Binding TotalCount,Mode=OneWay}" FontWeight="SemiBold"/>
                <Run Text=" 个收件对象"/>
            </TextBlock>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Border Style="{StaticResource CardStyle}" Margin="0" Padding="12,8">
                <WrapPanel Orientation="Horizontal">
                    <ComboBox x:Name="GroupComboBox" ItemsSource="{Binding Groups}"
                              SelectedItem="{Binding SelectedGroup}" DisplayMemberPath="Name"
                              Width="140" Margin="0,0,8,0" Padding="8,6"/>
                    <ui:TextBox Text="{Binding NewGroupName,UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="新分组名" Width="110" Margin="0,0,8,0"/>
                    <Button Content="添加分组" Command="{Binding AddGroupCommand}" Margin="0,0,4,0" Padding="12,6"/>
                    <Button Content="删除分组" Command="{Binding DeleteGroupCommand}" Padding="12,6"/>
                </WrapPanel>
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                <Button Content="从其他组复制" Command="{Binding ImportFromOtherGroupCommand}" Margin="0,0,4,0" Padding="12,6"/>
                <Button Content="导出" Command="{Binding ExportToExcelCommand}" Margin="0,0,4,0" Padding="12,6"/>
                <Button Content="导入" Command="{Binding ImportFromExcelCommand}" Padding="12,6"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0">
            <DataGrid x:Name="RecipientsGrid" ItemsSource="{Binding CurrentRecipients}" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      SelectionMode="Single" CellEditEnding="OnCellEditEnding"
                      PreviewKeyDown="OnGridPreviewKeyDown"
                      RowEditEnding="OnRowEditEnding"
                      LostFocus="OnGridLostFocus"
                      MouseLeftButtonUp="OnGridMouseClick"
                      MouseDoubleClick="OnGridDoubleClick"
                      GridLinesVisibility="Horizontal" AlternatingRowBackground="{StaticResource SurfaceBrush}"
                      FontSize="13" FontFamily="{StaticResource AppFontFamily}"
                      BorderThickness="0" Background="Transparent"
                      HeadersVisibility="Column"
                      Sorting="OnGridSorting"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      RowHeight="NaN"
                      IsSynchronizedWithCurrentItem="False">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="上移" Click="OnMoveUp"/>
                        <MenuItem Header="下移" Click="OnMoveDown"/>
                        <Separator/>
                        <MenuItem Header="删除" Click="OnDeleteRow"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="66" IsReadOnly="True" CanUserSort="False" CanUserResize="False">
                        <DataGridTemplateColumn.Header>
                            <CheckBox x:Name="HeaderCheckBox" Click="OnHeaderCheckBoxClick"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      ToolTip="全选/取消全选"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected,UpdateSourceTrigger=PropertyChanged}"
                                          Click="OnCheckClick" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="名称" Binding="{Binding Name,UpdateSourceTrigger=LostFocus}" Width="*" MinWidth="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="MaxHeight" Value="52"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="AcceptsReturn" Value="False"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="简称" Binding="{Binding ShortName,UpdateSourceTrigger=LostFocus}" Width="Auto" MinWidth="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="MaxHeight" Value="52"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="收件人(To)" Binding="{Binding ToEmails,UpdateSourceTrigger=LostFocus}" Width="*" MinWidth="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="MaxHeight" Value="52"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="抄送(Cc)" Binding="{Binding CcEmails,UpdateSourceTrigger=LostFocus}" Width="*" MinWidth="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="MaxHeight" Value="52"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="密送(Bcc)" Binding="{Binding BccEmails,UpdateSourceTrigger=LostFocus}" Width="*" MinWidth="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="MaxHeight" Value="52"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="备注" Binding="{Binding Remark,UpdateSourceTrigger=LostFocus}" Width="*" MinWidth="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="MaxHeight" Value="52"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Width="40" IsReadOnly="True" CanUserSort="False" CanUserResize="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="×" Click="OnDeleteRowClick" Tag="{Binding}"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{StaticResource DangerBrush}" FontWeight="Bold"
                                        Padding="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                                        ToolTip="删除此行" FontSize="14" Margin="2,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
