<UserControl x:Class="TailorMail.Views.PreviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="200" MaxWidth="280"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,0,0"
                Effect="{StaticResource ShadowSM}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Border Style="{StaticResource SectionTitleAccentStyle}"/>
                    <TextBlock Text="发送对象" Style="{StaticResource SectionTitleStyle}"/>
                    <Button x:Name="BtnPrevGroup" Click="OnPrevGroup" Margin="12,0,0,0" Width="28" Padding="0"
                            ToolTip="上一个">
                        <ui:SymbolIcon Symbol="ChevronUp24" FontSize="10"/>
                    </Button>
                    <Button x:Name="BtnNextGroup" Click="OnNextGroup" Margin="4,0,0,0" Width="28" Padding="0"
                            ToolTip="下一个">
                        <ui:SymbolIcon Symbol="ChevronDown24" FontSize="10"/>
                    </Button>
                </StackPanel>
                <ui:TextBox x:Name="SearchBox" PlaceholderText="搜索..." Margin="0,0,0,8"
                            TextChanged="OnSearchTextChanged" Icon="{ui:SymbolIcon Search24}"/>
                <ListBox Grid.Row="1" x:Name="ListGroups" DisplayMemberPath="Name"
                         BorderThickness="0" Background="Transparent"
                         FontFamily="{StaticResource AppFontFamily}"
                         SelectionChanged="OnGroupSelected"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0"
                Effect="{StaticResource ShadowLG}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="主题：" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="TxtSubject" TextWrapping="Wrap" FontWeight="Medium"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="收件人：" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="TxtTo" TextWrapping="Wrap" Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12"
                            x:Name="CcBccPanel" Visibility="Collapsed">
                    <TextBlock Text="抄送：" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="TxtCc" TextWrapping="Wrap" Foreground="{StaticResource SuccessBrush}"/>
                    <TextBlock Text="密送：" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="20,0,0,0"
                               x:Name="BccLabel"/>
                    <TextBlock x:Name="TxtBcc" TextWrapping="Wrap" Foreground="{StaticResource WarningBrush}"/>
                </StackPanel>

                <Border Grid.Row="3" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerRadiusMD}" ClipToBounds="True">
                    <wv2:WebView2 x:Name="PreviewBrowser" DefaultBackgroundColor="Transparent"/>
                </Border>

                <StackPanel Grid.Row="4" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Style="{StaticResource SectionTitleAccentStyle}"/>
                        <TextBlock Text="附件清单" Style="{StaticResource SectionTitleStyle}"/>
                    </StackPanel>
                    <ItemsControl x:Name="PanelAttachments"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
