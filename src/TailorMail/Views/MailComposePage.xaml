<UserControl x:Class="TailorMail.Views.MailComposePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Border Style="{StaticResource SectionTitleAccentStyle}"/>
                    <TextBlock Text="邮件主题" Style="{StaticResource SectionTitleStyle}"/>
                </StackPanel>
                <ui:TextBox Text="{Binding Subject,UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="请输入邮件主题，支持 {变量名} 格式" FontSize="14"
                            FontFamily="{StaticResource AppFontFamily}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="8,6">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <ComboBox x:Name="VariableCombo" Width="160" Margin="0,0,8,0" Padding="8,6"/>
                    <Button Click="OnInsertVariable" Margin="0,0,8,0" Padding="8,4" ToolTip="插入变量到光标位置">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Add24" FontSize="14" Margin="0,0,4,0"/>
                            <TextBlock Text="插入变量"/>
                        </StackPanel>
                    </Button>
                    <Border Background="{StaticResource BorderSubtleBrush}" Width="1" Margin="4,2"/>
                    <ToggleButton x:Name="BoldBtn" Click="OnToggleBold" ToolTip="粗体 (Ctrl+B)" Margin="8,0,0,0" Width="36" Height="28" FontSize="13">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="B" FontWeight="Bold"/>
                            <TextBlock Text="⌘B" FontSize="8" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Bottom" Margin="2,0,0,0"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="ItalicBtn" Click="OnToggleItalic" ToolTip="斜体 (Ctrl+I)" Margin="4,0,0,0" Width="36" Height="28" FontSize="13">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="I" FontStyle="Italic"/>
                            <TextBlock Text="⌘I" FontSize="8" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Bottom" Margin="2,0,0,0"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="UnderlineBtn" Click="OnToggleUnderline" ToolTip="下划线 (Ctrl+U)" Margin="4,0,0,0" Width="36" Height="28" FontSize="13">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock TextDecorations="Underline" Text="U"/>
                            <TextBlock Text="⌘U" FontSize="8" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Bottom" Margin="2,0,0,0"/>
                        </StackPanel>
                    </ToggleButton>
                    <Border Background="{StaticResource BorderSubtleBrush}" Width="1" Margin="8,2"/>
                    <Button Content="A↑" Click="OnIncreaseFontSize" ToolTip="增大字号" Margin="8,0,0,0" Padding="6,4" Width="32" Height="28" FontSize="11" FontWeight="Bold"/>
                    <Button Content="A↓" Click="OnDecreaseFontSize" ToolTip="缩小字号" Margin="4,0,0,0" Padding="6,4" Width="32" Height="28" FontSize="11" FontWeight="Bold"/>
                    <TextBlock x:Name="FontSizeLabel" Text="16" VerticalAlignment="Center" Margin="6,0,0,0"
                               FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" MinWidth="20"/>
                    <Border Background="{StaticResource BorderSubtleBrush}" Width="1" Margin="8,2"/>
                    <Border x:Name="ColorPreview" Width="22" Height="22" CornerRadius="4"
                            Background="Black" Margin="0,0,0,0" VerticalAlignment="Center"
                            BorderBrush="{StaticResource AccentBrush}" BorderThickness="2"
                            Cursor="Hand" MouseLeftButtonUp="OnColorPickerClick" ToolTip="文字颜色"/>
                    <Popup x:Name="ColorPopup" StaysOpen="False" Placement="Bottom">
                        <Border Background="{StaticResource SurfaceElevatedBrush}" CornerRadius="8" Padding="12"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                Effect="{StaticResource ShadowLG}">
                            <StackPanel>
                                <WrapPanel Width="220" Orientation="Horizontal">
                                    <Rectangle Width="24" Height="24" Fill="Black" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="Black" RadiusX="4" RadiusY="4"/>
                                    <Rectangle Width="24" Height="24" Fill="#333333" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#333333" RadiusX="4" RadiusY="4"/>
                                    <Rectangle Width="24" Height="24" Fill="#666666" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#666666" RadiusX="4" RadiusY="4"/>
                                    <Rectangle Width="24" Height="24" Fill="#999999" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#999999" RadiusX="4" RadiusY="4"/>
                                    <Rectangle Width="24" Height="24" Fill="#DC2626" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#DC2626" RadiusX="4" RadiusY="4"/>
                                    <Rectangle Width="24" Height="24" Fill="#EA580C" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#EA580C" RadiusX="4" RadiusY="4"/>
                                    <Rectangle Width="24" Height="24" Fill="#D97706" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#D97706" RadiusX="4" RadiusY="4"/>
                                    <Rectangle Width="24" Height="24" Fill="#059669" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#059669" RadiusX="4" RadiusY="4"/>
                                    <Rectangle Width="24" Height="24" Fill="#2563EB" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#2563EB" RadiusX="4" RadiusY="4"/>
                                    <Rectangle Width="24" Height="24" Fill="#7C3AED" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#7C3AED" RadiusX="4" RadiusY="4"/>
                                    <Rectangle Width="24" Height="24" Fill="#DB2777" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#DB2777" RadiusX="4" RadiusY="4"/>
                                    <Rectangle Width="24" Height="24" Fill="#0891B2" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#0891B2" RadiusX="4" RadiusY="4"/>
                                    <Rectangle Width="24" Height="24" Fill="#4F46E5" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#4F46E5" RadiusX="4" RadiusY="4"/>
                                    <Rectangle Width="24" Height="24" Fill="#15803D" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#15803D" RadiusX="4" RadiusY="4"/>
                                </WrapPanel>
                                <Border Background="{StaticResource BorderSubtleBrush}" Height="1" Margin="0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="自定义颜色" VerticalAlignment="Center" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                                    <ui:TextBox x:Name="CustomColorInput" Width="80" PlaceholderText="#RRGGBB"
                                                FontFamily="{StaticResource AppMonoFontFamily}" FontSize="12" Padding="6,4"/>
                                    <Button Content="应用" Click="OnApplyCustomColor" Margin="4,0,0,0" Padding="8,4" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0">
            <RichTextBox x:Name="Editor" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         FontFamily="{StaticResource AppFontFamily}" FontSize="16" Padding="12"
                         BorderThickness="0" TextChanged="OnEditorTextChanged"
                         SelectionChanged="OnEditorSelectionChanged"
                         SpellCheck.IsEnabled="False" AcceptsTab="False"
                         Background="Transparent"/>
        </Border>

        <TextBlock Grid.Row="3" Text="提示：使用 {变量名} 格式插入变量，如 {名称}，系统将自动替换为对应值"
                   Style="{StaticResource CaptionTextStyle}" Margin="0,8,0,0"/>
    </Grid>
</UserControl>
