<UserControl x:Class="TailorMail.Views.MailComposePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="内容撰写" Style="{StaticResource PageTitleStyle}" Margin="0,0,0,4"/>
            <TextBlock Text="编辑邮件主题和正文，支持变量插入和富文本格式" Style="{StaticResource CaptionTextStyle}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="邮件主题" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8"/>
                <ui:TextBox Text="{Binding Subject,UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="请输入邮件主题，支持 {变量名} 格式" FontSize="14"
                            FontFamily="{StaticResource AppFontFamily}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="VariableCombo" Width="160" Margin="0,0,8,0" Padding="8,6"/>
                <Button Content="插入变量" Click="OnInsertVariable" Margin="0,0,8,0" Padding="12,4"/>
                <Border Background="{StaticResource BorderSubtleBrush}" Width="1" Margin="4,2"/>
                <ToggleButton x:Name="BoldBtn" Content="B" FontWeight="Bold" Width="32" Click="OnToggleBold" ToolTip="粗体" Margin="8,0,0,0"/>
                <ToggleButton x:Name="ItalicBtn" Content="I" FontStyle="Italic" Width="32" Click="OnToggleItalic" ToolTip="斜体" Margin="4,0,0,0"/>
                <ToggleButton x:Name="UnderlineBtn" Width="32" Click="OnToggleUnderline" ToolTip="下划线" Margin="4,0,0,0">
                    <TextBlock TextDecorations="Underline" Text="U"/>
                </ToggleButton>
                <Border Background="{StaticResource BorderSubtleBrush}" Width="1" Margin="8,2"/>
                <Button Content="A↑" Click="OnIncreaseFontSize" ToolTip="增大字号" Margin="8,0,0,0" Padding="6,4" FontSize="12" FontWeight="Bold"/>
                <Button Content="A↓" Click="OnDecreaseFontSize" ToolTip="缩小字号" Margin="4,0,0,0" Padding="6,4" FontSize="12" FontWeight="Bold"/>
                <TextBlock x:Name="FontSizeLabel" Text="16" VerticalAlignment="Center" Margin="6,0,0,0"
                           FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" MinWidth="20"/>
                <Border Background="{StaticResource BorderSubtleBrush}" Width="1" Margin="8,2"/>
                <TextBlock Text="A" VerticalAlignment="Center" Margin="4,0,2,0" FontWeight="Bold" FontSize="14"/>
                <Border x:Name="ColorPreview" Width="20" Height="20" CornerRadius="3"
                        Background="Black" Margin="0,0,2,0" VerticalAlignment="Center"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"/>
                <Button Content="▼" Click="OnColorPickerClick" FontSize="8" Padding="4,2" ToolTip="文字颜色" Margin="0,0,0,0"/>
                <Popup x:Name="ColorPopup" StaysOpen="False" Placement="Bottom">
                    <Border Background="{StaticResource SurfaceElevatedBrush}" CornerRadius="8" Padding="12"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                        <WrapPanel Width="200" Orientation="Horizontal">
                            <Rectangle Width="24" Height="24" Fill="Black" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="Black"/>
                            <Rectangle Width="24" Height="24" Fill="#333333" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#333333"/>
                            <Rectangle Width="24" Height="24" Fill="#666666" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#666666"/>
                            <Rectangle Width="24" Height="24" Fill="#999999" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#999999"/>
                            <Rectangle Width="24" Height="24" Fill="#DC2626" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#DC2626"/>
                            <Rectangle Width="24" Height="24" Fill="#EA580C" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#EA580C"/>
                            <Rectangle Width="24" Height="24" Fill="#D97706" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#D97706"/>
                            <Rectangle Width="24" Height="24" Fill="#059669" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#059669"/>
                            <Rectangle Width="24" Height="24" Fill="#2563EB" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#2563EB"/>
                            <Rectangle Width="24" Height="24" Fill="#7C3AED" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#7C3AED"/>
                            <Rectangle Width="24" Height="24" Fill="#DB2777" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#DB2777"/>
                            <Rectangle Width="24" Height="24" Fill="#0891B2" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#0891B2"/>
                            <Rectangle Width="24" Height="24" Fill="#4F46E5" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#4F46E5"/>
                            <Rectangle Width="24" Height="24" Fill="#15803D" Margin="2" Cursor="Hand" MouseLeftButtonUp="OnColorSelected" Tag="#15803D"/>
                        </WrapPanel>
                    </Border>
                </Popup>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0">
            <RichTextBox x:Name="Editor" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         FontFamily="{StaticResource AppFontFamily}" FontSize="16" Padding="12"
                         BorderThickness="0" TextChanged="OnEditorTextChanged"
                         SelectionChanged="OnEditorSelectionChanged"
                         SpellCheck.IsEnabled="False" AcceptsTab="False"
                         Background="Transparent"/>
        </Border>

        <TextBlock Grid.Row="4" Text="提示：使用 {变量名} 格式插入变量，如 {名称}，系统将自动替换为对应值"
                   Style="{StaticResource CaptionTextStyle}" Margin="0,8,0,0"/>
    </Grid>
</UserControl>
