<ui:FluentWindow x:Class="TailorMail.Views.GroupSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="从其他分组复制"
        Width="520" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="{StaticResource UIFontFamily}"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Style="{StaticResource SectionTitleAccentStyle}"/>
            <TextBlock Text="勾选要复制的发送对象" Style="{StaticResource SectionTitleStyle}"/>
        </StackPanel>

        <TreeView Grid.Row="1" x:Name="GroupTree" BorderThickness="1"
                  BorderBrush="{StaticResource BorderSubtleBrush}" Background="{StaticResource SurfaceElevatedBrush}"
                  FontFamily="{StaticResource UIFontFamily}" Margin="0,0,0,12">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Recipients}">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding IsChecked}" Click="OnGroupCheckClick" Margin="0,0,6,0"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding GroupName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <HierarchicalDataTemplate.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding IsChecked}" Click="OnRecipientCheckClick" Margin="0,0,6,0"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding RecipientName}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </HierarchicalDataTemplate.ItemTemplate>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Content="取消" Appearance="Secondary" Click="OnCancel" Margin="0,0,8,0" Padding="16,6"/>
            <ui:Button Content="复制" Appearance="Primary" Click="OnImport" Padding="16,6"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
