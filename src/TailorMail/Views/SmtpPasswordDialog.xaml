<ui:FluentWindow x:Class="TailorMail.Views.SmtpPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="输入 SMTP 密码"
        Width="420" Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="{StaticResource AppFontFamily}"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Border Style="{StaticResource SectionTitleAccentStyle}"/>
                <TextBlock Text="SMTP 密码验证" Style="{StaticResource SectionTitleStyle}"/>
            </StackPanel>
            <TextBlock Text="密码仅在本次发送时使用，不会保存到配置文件" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,12,0,0">
            <PasswordBox x:Name="PasswordBox" FontFamily="{StaticResource AppFontFamily}" Padding="8,6"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <ui:Button Content="取消" Appearance="Secondary" Click="OnCancel" Margin="0,0,8,0" Padding="16,6"/>
            <ui:Button Content="确认发送" Appearance="Primary" Click="OnConfirm" Padding="16,6"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
