<ui:FluentWindow x:Class="TailorMail.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="千函 - TailorMail" Height="800" Width="1200"
        MinWidth="960" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        FontFamily="{StaticResource AppFontFamily}"
        Background="{StaticResource SurfaceBrush}">
    <Grid>
        <Grid.Background>
            <DrawingBrush Drawing="{Binding Source={StaticResource NoiseBrush}, Path=Drawing}" Opacity="0.3"/>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title=""
                     HorizontalAlignment="Stretch"
                     ShowMaximize="True" ShowMinimize="True" ShowClose="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/logo_64.png" Width="16" Height="16"/>
            </ui:TitleBar.Icon>
            <ui:TitleBar.CenterContent>
                <Border x:Name="PillStepper" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="20" Padding="4" Margin="0,2,0,0">
                    <ItemsControl x:Name="StepItems">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Click="OnStepClick" Tag="{Binding Index}"
                                        Background="Transparent" BorderThickness="0" Padding="0" Margin="0" Cursor="Hand">
                                    <Border CornerRadius="16" Padding="14,6" MinWidth="90">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding State}" Value="Current">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                        <Setter Property="Effect" Value="{StaticResource ShadowAccent}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="Completed">
                                                        <Setter Property="Background" Value="{StaticResource AccentLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock FontWeight="SemiBold" FontSize="12"
                                                       VerticalAlignment="Center" Margin="0,0,6,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                                        <Setter Property="Text" Value="{Binding DisplayIndex}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding State}" Value="Current">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding State}" Value="Completed">
                                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                                <Setter Property="Text" Value="✓"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock VerticalAlignment="Center" FontSize="13">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                                        <Setter Property="FontWeight" Value="Medium"/>
                                                        <Setter Property="Text" Value="{Binding Label}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding State}" Value="Current">
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding State}" Value="Completed">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                                <Setter Property="FontWeight" Value="Medium"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </ui:TitleBar.CenterContent>
        </ui:TitleBar>

        <Border Grid.Row="1" x:Name="AccentBar" Height="3" Margin="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="{StaticResource AccentColor}" Offset="0"/>
                    <GradientStop Color="#4DA6E8" Offset="0.3"/>
                    <GradientStop Color="Transparent" Offset="0.6"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <ContentControl Grid.Row="2" x:Name="MainContent" Margin="24,8,24,16"
                        RenderTransformOrigin="0.5,0.5">
            <ContentControl.RenderTransform>
                <TranslateTransform x:Name="MainContentTransform" Y="0"/>
            </ContentControl.RenderTransform>
        </ContentControl>

        <StackPanel Grid.Row="2" x:Name="SkeletonPanel" Margin="24,8,24,16" Visibility="Collapsed">
            <Border Style="{StaticResource CardStyle}" Margin="0">
                <StackPanel Margin="4">
                    <Border Style="{StaticResource SkeletonLineStyle}" Width="180" Margin="0,0,0,12"/>
                    <Border Style="{StaticResource SkeletonLineStyle}" Width="100" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource SkeletonLineStyle}" Width="320" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource SkeletonLineStyle}" Width="240"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="0">
                <StackPanel Margin="4">
                    <Border Style="{StaticResource SkeletonLineStyle}" Width="140" Margin="0,0,0,12"/>
                    <Border Style="{StaticResource SkeletonLineStyle}" Width="400" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource SkeletonLineStyle}" Width="360"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Row="3" Background="{StaticResource SurfaceElevatedBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0"
                Padding="24,10,24,12"
                Effect="{StaticResource ShadowSM}">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtStepHint" Text="步骤 1/6 · 收件选择"
                               Style="{StaticResource CaptionTextStyle}"/>
                    <TextBlock Text=" — " Foreground="{StaticResource BorderSubtleBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtStepDesc"
                               Style="{StaticResource CaptionTextStyle}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button x:Name="BtnPrev" Content="上一步" Padding="16,6" Margin="0,0,8,0"
                               Click="BtnPrev_Click" Appearance="Secondary"/>
                    <ui:Button x:Name="BtnNewMail" Content="新邮件" Padding="16,6" Margin="0,0,8,0"
                               Click="BtnNewMail_Click" Appearance="Primary"/>
                    <ui:Button x:Name="BtnNext" Content="下一步" Padding="20,6" Click="BtnNext_Click"/>
                    <ui:DropDownButton x:Name="BtnMenu" Padding="8,6" Margin="8,0,0,0"
                                       Appearance="Secondary">
                        <ui:DropDownButton.Icon>
                            <ui:SymbolIcon Symbol="MoreVertical24"/>
                        </ui:DropDownButton.Icon>
                        <ui:DropDownButton.Flyout>
                            <ContextMenu>
                                <MenuItem Header="设置" Click="BtnSettings_Click"/>
                                <MenuItem Header="关于" Click="BtnAbout_Click"/>
                            </ContextMenu>
                        </ui:DropDownButton.Flyout>
                    </ui:DropDownButton>
                </StackPanel>
            </Grid>
        </Border>

        <ui:SnackbarPresenter x:Name="SnackbarHost" Grid.RowSpan="4" VerticalAlignment="Bottom" HorizontalAlignment="Center"
              Margin="0,0,0,20">
        </ui:SnackbarPresenter>
    </Grid>
</ui:FluentWindow>
